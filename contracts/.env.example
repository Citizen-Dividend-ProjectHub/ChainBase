# Sepolia RPC endpoint (Infura or Alchemy)
SEPOLIA_RPC_URL=

# Private key of the deployer / contract owner wallet (no 0x prefix or with, either works)
DEPLOYER_PRIVATE_KEY=

# Optional: override the USDC token address used on Sepolia.
# Defaults to Circle's public Sepolia USDC address if unset — verify this is still current before deploying.
USDC_ADDRESS_SEPOLIA=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
